python3 -c import json, pathlib, requests; cfg=json.loads(pathlib.Path.home().joinpath(".ict-engine", "tvremix_mcp.json").read_text()); url=cfg.get("url") or "https://tvremix.xyz/api/mcp/v1"; key=cfg.get("api_key") or ""; r=requests.post(url, headers={"Accept":"application/json, text/event-stream", "Authorization":"Bearer "+key}, json={"jsonrpc":"2.0","id":1,"method":"tools/list","params":{}}, timeout=20); print("status", r.status_code); print("content_type", r.headers.get("content-type", "")); text=r.text[:500].replace("\n", " "); print("body_prefix", text); r.raise_for_status(); payload=r.json(); print("tools_len", len(payload.get("result", {}).get("tools", [])))
