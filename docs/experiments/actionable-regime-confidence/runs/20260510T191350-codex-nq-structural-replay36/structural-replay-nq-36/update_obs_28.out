    "agent_prompts": {
      "prompts": [
        {
          "id": "dataset_audit",
          "objective": "Audit whether the dataset and command context are sufficient for trustworthy iteration.",
          "priority": "high",
          "stage": "dataset_audit",
          "success_criteria": [
            "Flag low sample size or missing paired-market evidence before approving major factor changes",
            "If this run is not comparable to prior runs, tell the next agent not to over-interpret score deltas"
          ],
          "suggested_files": [
            "src/data/loader.rs",
            "src/main.rs",
            "src/factor_lab/research.rs"
          ],
          "system_prompt": "You are the dataset-audit agent. Check whether the current dataset scope, paired market coverage, and command context are sufficient before making factor or model changes.",
          "user_prompt": "Symbol=NQ data_path=update-command paired_data_path=None candles=1 paired_candles=None source_command=update"
        },
        {
          "id": "update_feedback_review",
          "objective": "Review the newly realized outcome and decide what the next agent iteration should target.",
          "priority": "high",
          "stage": "feedback_update",
          "success_criteria": [
            "If duplicate_feedback_skipped is true, do not infer a new learning event",
            "If factor_alignment and realized_outcome disagree repeatedly, prioritize evidence-mapping review or factor replacement",
            "If updated_trade_outcome improves while factor scores stay weak, review BBN calibration before editing factor code"
          ],
          "suggested_files": [
            "src/main.rs",
            "src/factors/weight_updater.rs",
            "src/bbn/trading/topology.rs",
            "src/agent/prompts.rs"
          ],
          "system_prompt": "You are the realized-feedback agent. Use the updated trade_outcome distribution plus factor scorecards to decide whether the latest result strengthens confidence, exposes a factor weakness, or suggests a problem in evidence mapping.",
          "user_prompt": "Symbol=NQ entry_quality=medium factor_alignment=mixed factor_uncertainty=low realized_outcome=loss structural_learning_semantics=class=negative_executed success_credit=0.000 observation_weight=1.000 feedback_records_applied=1 updated_trade_outcome={\"breakeven\": 0.06740432138802777, \"loss\": 0.3536049106791642, \"win\": 0.5789907679328081} iteration_queue=[]"
        },
        {
          "id": "factor_triage",
          "objective": "Select which factors to keep, tune, observe, or replace.",
          "priority": "high",
          "stage": "factor_research",
          "success_criteria": [
            "Prioritize replace > tune > observe > keep",
            "Only recommend replacing a factor when its action is replace or replacement_candidate=true",
            "Use the factor-specific agent prompt as the acceptance rule for the next iteration"
          ],
          "suggested_files": [
            "src/factor_lab/factor_definition.rs",
            "src/factors/registry.rs",
            "src/factors/weight_updater.rs"
          ],
          "system_prompt": "You are the factor-iteration agent. Use only the supplied scorecards and feedback summary to decide which factor edits are justified. Do not invent success criteria; follow the thresholds embedded in each factor prompt.",
          "user_prompt": "Symbol=NQ top_scorecards=[] iteration_queue=[] feedback_summary=records:33 wins:17 losses:16 avg_pnl:0.001441 factor_success_rates:{}"
        },
        {
          "id": "feedback_review",
          "objective": "Review which factors are failing by regime and whether weight updates should be trusted.",
          "priority": "medium",
          "stage": "feedback_learning",
          "success_criteria": [
            "Flag factors with narrow regime coverage or unstable walk-forward",
            "Do not promote a weaker factor just because it has higher recent win rate on small sample"
          ],
          "suggested_files": [
            "src/state/types.rs",
            "src/factors/regime_conditional.rs",
            "src/factors/weight_updater.rs"
          ],
          "system_prompt": "You are the feedback-diagnostics agent. Compare factor success rates, grading, and weaknesses. Focus on regime-conditional failure and persistent underperformance.",
          "user_prompt": "Symbol=NQ feedback_total=33 avg_pnl=0.001441 weak_factors=[]"
        },
        {
          "id": "update_diff_review",
          "objective": "Review whether the realized update materially changed model state.",
          "priority": "high",
          "stage": "update_diff",
          "success_criteria": [
            "If duplicate_feedback_skipped is true, recommend no model change",
            "If outcome probabilities changed materially but factor scores did not, investigate BBN evidence mapping"
          ],
          "suggested_files": [
            "src/main.rs",
            "src/bbn/trading/topology.rs",
            "src/factors/weight_updater.rs"
          ],
          "system_prompt": "You are the update-diff agent. Use the trade_outcome probability deltas and factor score deltas to judge whether this realized result should change factor code, evidence mapping, or neither.",
          "user_prompt": "Symbol=NQ duplicate_feedback_skipped=false trade_outcome_deltas=[ProbabilityDiff { state: \"breakeven\", previous: Some(0.07489369043114195), new: 0.06740432138802777, delta: -0.0074893690431141885 }, ProbabilityDiff { state: \"loss\", previous: Some(0.28178323408796024), new: 0.3536049106791642, delta: 0.07182167659120398 }, ProbabilityDiff { state: \"win\", previous: Some(0.6433230754808978), new: 0.5789907679328081, delta: -0.06433230754808972 }] factor_score_deltas=[]"
        },
        {
          "id": "artifact_decision_review",
          "objective": "Review artifact-driven actions and ensure they align with the next code or model iteration.",
          "priority": "high",
          "stage": "artifact_decision",
          "success_criteria": [
            "Explicitly state whether artifact evidence strengthens promotion, rollback review, or observation only",
            "Do not ignore rule-break effects when artifact review versions changed",
            "Use consumed validation trends when realized artifact outcomes are available",
            "Name the artifact-driven factor/family targets before recommending code edits"
          ],
          "suggested_files": [
            "src/main.rs",
            "src/state/types.rs",
            "src/agent/prompts.rs"
          ],
          "system_prompt": "You are the artifact-decision agent. Use the artifact decision section to validate whether the current pending/execution artifacts strengthen promotion, trigger rollback review, or should only be observed.",
          "user_prompt": "Symbol=NQ artifact_summary=actionable_artifacts=96 latest_promotable=Some(\"ensemble-vote:analyze:2026-05-10T11:21:02Z\") rule_breaks=0 consumed_trend=no_consumed_validation consumed_targets=[] consumed_trend_status=no_consumed_validation consumed_trend_reason=no_consumed_artifacts highlighted_actions=[\"factor:structure_ict status=promotion_supporting reason=latest_action=Some(\\\"tune\\\") research_action=None backtest_action=None update_action=None consumed_validation_status=insufficient_consumed_history consumed_validation_reason=no_comparisons_available min_window=3\", \"family:cross_market_smt status=promotion_supporting reason=research_state=None backtest_state=None update_state=None consumed_validation_status=insufficient_consumed_history consumed_validation_reason=no_comparisons_available min_window=3\", \"family:options_hedging status=promotion_supporting reason=research_state=None backtest_state=None update_state=None consumed_validation_status=insufficient_consumed_history consumed_validation_reason=no_comparisons_available min_window=3\", \"family:other status=promotion_supporting reason=research_state=None backtest_state=None update_state=None consumed_validation_status=insufficient_consumed_history consumed_validation_reason=no_comparisons_available min_window=3\", \"learning_semantics=class=negative_executed success_credit=0.000 observation_weight=1.000\"] top_factor_trends=[\"structure_ict:promotion_supporting:162.5151515151515\", \"cross_market_smt:observe:100\"] top_family_trends=[\"cross_market_smt:promotion_supporting:Some(0.1225)\", \"options_hedging:promotion_supporting:Some(0.14593761276711903)\", \"other:promotion_supporting:Some(0.2882083772282027)\"] top_rule_break_effects=[] top_consumed_trends=[]"
