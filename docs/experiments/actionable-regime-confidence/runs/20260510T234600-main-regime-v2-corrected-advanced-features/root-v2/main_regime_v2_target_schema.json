  "blocked_predictor_prefixes": [
    "future_",
    "target_"
  ],
  "target_definitions": {
    "Crisis": "target_extreme_stress == true OR future_absret_h8h >= train_context_pool_q90; evaluated before Bull/Bear/Sideways",
    "Sideways": "target_range_consolidation == true AND NOT Crisis",
    "Bull": "future_ret_h8h >= train_context_pool_q65 AND NOT Crisis AND NOT Sideways",
    "Bear": "future_ret_h8h <= train_context_pool_q35 AND NOT Crisis AND NOT Sideways",
    "Manipulation": "not materialized from this OHLCV-derived table; requires direct tick/order-flow/L2/order-lifecycle or crypto event/social evidence",
    "UnknownOrMixed": "residual bucket after Crisis/Sideways/Bull/Bear"
  },
